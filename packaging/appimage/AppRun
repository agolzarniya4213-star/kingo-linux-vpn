#!/bin/sh
set -eu

HERE="$(dirname "$(readlink -f "$0")")"
export PATH="$HERE/usr/bin:$PATH"
export LD_LIBRARY_PATH="$HERE/usr/lib:${LD_LIBRARY_PATH:-}"

if [ "${1:-}" = "--daemon" ]; then
    exec "$HERE/usr/bin/kingo-linux-vpn-daemon"
fi

if [ "${1:-}" = "--ui" ]; then
    exec "$HERE/usr/bin/kingo-linux-vpn-ui"
fi

exec "$HERE/usr/bin/kingo-linux-vpn-ui"
